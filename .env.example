# ============================================================
# Dialer by LaunchCraft — environment variables
# Copy this file to `.env.local` and fill in the blanks.
# Production URL:  https://dialer.launchcraft.studio
# Parent brand:    https://launchcraft.studio
# ============================================================

# -------- App --------
# In production set this to https://dialer.launchcraft.studio
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -------- Supabase (Postgres + Storage — native SDK) --------
# https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=dialer
SUPABASE_STORAGE_BUCKET_RECORDINGS=recordings
SUPABASE_STORAGE_BUCKET_VOICEMAILS=voicemail-drops

# CLI-only (export in your shell, do not bundle):
#   SUPABASE_ACCESS_TOKEN
#   SUPABASE_PROJECT_REF

# -------- Auth (JWT) --------
# Generate with: openssl rand -base64 48     (or `pnpm keys:jwt`)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# -------- Encryption (AES-256-GCM) for Twilio credentials at rest --------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# -------- Browser Push Notifications (Web Push / VAPID) --------
# Generate with: pnpm dlx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@demo.com

# -------- Optional SMTP (meeting confirmations) --------
# https://resend.com/api-keys
RESEND_API_KEY=

# -------- Twilio dev --------
# Public base URL Twilio can reach (ngrok/cloudflared HTTPS URL in dev)
TWILIO_STATUS_CALLBACK_BASE_URL=

# Set to "true" only in local dev to bypass signature validation.
DEV_SKIP_WEBHOOK_SIGNATURE=false

# -------- Observability --------
LOG_LEVEL=info
